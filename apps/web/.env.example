# WEFLOW — Environment Variables Example
#
# 복사: `cp apps/web/.env.example apps/web/.env.local` 후 실제 값으로 교체.
# 모든 키는 `apps/web/lib/config.ts` 또는 `app/api/*/route.ts`에서 참조됨.

# ─── Resend (진단 폼 제출 메일 발송) ──────────────────────────
# https://resend.com/api-keys 에서 발급
RESEND_API_KEY=
# 발신 도메인은 Resend에서 verify된 도메인이어야 함. dev에선 `onboarding@resend.dev` 사용 가능.
RESEND_FROM_EMAIL=hello@weflowlab.kr
# 진단 신청 알림을 받을 이메일 (운영자)
OWNER_EMAIL=

# ─── Public — 분석/픽셀 (production에서만 노출) ───────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_NAVER_WISETOOL_ID=
NEXT_PUBLIC_KAKAO_PIXEL_ID=

# ─── Public — 외부 채널 ────────────────────────────────────────
NEXT_PUBLIC_KAKAO_CHANNEL_URL=
NEXT_PUBLIC_DAANGN_PLACE_URL=

# ─── SEO 사이트 소유 인증 ─────────────────────────────────────
GOOGLE_SITE_VERIFICATION=
NAVER_SITE_VERIFICATION=
